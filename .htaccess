<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On

    # Handle Authorization Header (needed for Laravel API)
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Real files and dirs → serve directly (assets/, plugins/, platform/, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # /platform root → redirect to organizer login
    RewriteRule ^platform/?$ /platform/login [R=302,L]

    # Redirect /page.php → /page (canonical clean URL)
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Frontend clean URLs: /events → events.php, /blog → blog.php, etc.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^/.]+)$ $1.php [NC,L]

    # Everything else (API, /login, /storage/*, /platform/*) → Laravel bridge
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ platform/index.php [L]
</IfModule>
